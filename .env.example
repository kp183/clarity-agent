# Clarity Agent — Environment Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env

# === LLM Provider ===
# Options: groq | bedrock
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_ID=llama-3.3-70b-versatile

# === AWS Configuration (if using Bedrock) ===
AWS_PROFILE_NAME=default
AWS_REGION_NAME=us-east-1
BEDROCK_MODEL_ID=amazon.titan-text-express-v1

# === MCP Server ===
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8001

# === Model Parameters ===
MAX_TOKENS=4096
TEMPERATURE=0.3
TOP_P=0.9

# === Database ===
# SQLite for local dev, PostgreSQL for production
DATABASE_URL=sqlite:///clarity.db
# DATABASE_URL=postgresql://user:password@localhost:5432/clarity_db

# === Monitoring ===
MONITORING_INTERVAL_SECONDS=30
ALERT_THRESHOLD_ERROR_RATE=0.15

# === Application ===
DEBUG=false
LOG_LEVEL=INFO

# === Security ===
JWT_SECRET_KEY=change_me_to_a_random_secret
AUTH_ENABLED=false

# === Optional Integrations ===
SLACK_WEBHOOK_URL=
JIRA_BASE_URL=
JIRA_PROJECT_KEY=INC
JIRA_EMAIL=
JIRA_API_TOKEN=

# === Error Monitoring ===
# Get a free DSN at sentry.io
SENTRY_DSN=
